# ============ OpenAI(脚本生成 + TTS 配音) ============
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ============ TTS ============
TTS_PROVIDER=openai
TTS_VOICE=alloy

# ============ 输出 / 素材 ============
OUTPUT_DIR=./output
ASSETS_DIR=./assets
LOG_LEVEL=INFO

# ============ Digital Human(可选,GPU 服务器跑 InfiniteTalk) ============
# 留空表示 不启用数字人,使用静态背景图模式(任何机器都能跑)
# 启用后, GPU 服务器需要先按 docs/INFINITETALK_DEPLOY.md 把 InfiniteTalk 包装成 HTTP API
INFINITETALK_API_URL=
INFINITETALK_API_KEY=
INFINITETALK_RESOLUTION=480p
INFINITETALK_REFERENCE_IMAGE=assets/avatar.png
INFINITETALK_TIMEOUT=1800
