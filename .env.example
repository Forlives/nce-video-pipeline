# =================== LLM(脚本改编)===================
# 兼容 OpenAI / Claude / DeepSeek / OneAPI / OpenRouter / 火山兼容版 / 任意 OpenAI 兼容中转

# --- 选项 A: OpenAI 官方 ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- 选项 B: OpenRouter(海外, 一个 key 玩遍 Claude/GPT/Gemini/Llama) ---
# OPENAI_API_KEY=sk-or-v1-xxxxx
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-3.5-sonnet

# --- 选项 C: DeepSeek 官方(国内便宜, 中文友好) ---
# OPENAI_API_KEY=sk-deepseek-xxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- 选项 D: 自建/第三方 OneAPI 中转 ---
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://your-oneapi-domain/v1
# OPENAI_MODEL=claude-3-5-sonnet

# =================== TTS(配音)独立配置 ===================
# 留空则回退使用上面的 OPENAI_API_KEY / OPENAI_BASE_URL
# 推荐: LLM 走中转省钱, TTS 走 OpenAI 官方保证音质
TTS_PROVIDER=openai
TTS_VOICE=alloy
TTS_API_KEY=
TTS_BASE_URL=

# =================== 输出 / 素材 ===================
OUTPUT_DIR=./output
ASSETS_DIR=./assets
LOG_LEVEL=INFO

# =================== Digital Human(可选, GPU 服务器跑 InfiniteTalk)===================
# 留空表示不启用数字人, 使用静态背景图模式(任何机器都能跑)
INFINITETALK_API_URL=
INFINITETALK_API_KEY=
INFINITETALK_RESOLUTION=480p
INFINITETALK_REFERENCE_IMAGE=assets/avatar.png
INFINITETALK_TIMEOUT=1800
